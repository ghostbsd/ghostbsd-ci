pipeline {
    agent {
        node {
            label 'builder1'
        }
    }

    options {
        timestamps()
    }

    stages {
        stage('Clean') {
            steps {
                sh 'make clean'
            }
        }

        stage('Build') {
            steps {
                sh 'make -j24 buildworld buildkernel'
            }
        }
    }

    post {
        success {
            deleteDir()
        }
    }
}